{
  "name": "loony-dotenv",
  "version": "0.1.2",
  "description": "Simple environment loader that reads .env files and automatically populates process.env for Node.js applications.",
  "type": "module",
  "private": false,
  "main": "./lib/index.cjs",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.cjs"
    }
  },
  "files": [
    "lib"
  ],
  "keywords": [
    "loony-env",
    "loony-dotenv",
    "dotenv",
    "env"
  ],
  "author": "Sankar Boro",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/loony-js/loony-dotenv.git"
  },
  "scripts": {
    "clean": "rm -rf lib dist",
    "build": "npm run clean && tsup ./index.ts --format cjs,esm --dts --out-dir lib",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
